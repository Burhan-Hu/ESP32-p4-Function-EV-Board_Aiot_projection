  command = E:\Tools\ESP-IDF\Espressif\tools\cmake\3.30.2\bin\cmake.exe -P E:\Tools\ESP-IDF\Espressif\frameworks\esp-idf-v5.5.2\esp_workspace\aiot_agent\build\CMakeFiles\VerifyGlobs.cmake
