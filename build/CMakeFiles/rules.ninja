rule CLEAN_ADDITIONAL
  command = E:\Tools\ESP-IDF\Espressif\tools\cmake\3.30.2\bin\cmake.exe -DCONFIG=$CONFIG -P CMakeFiles\clean_additional.cmake
  description = Cleaning additional files...


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = E:\Tools\ESP-IDF\Espressif\tools\ninja\1.12.1\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = E:\Tools\ESP-IDF\Espressif\tools\ninja\1.12.1\ninja.exe -t targets
  description = All primary targets available:

